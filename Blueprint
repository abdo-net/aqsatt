```typescript
function calculateInstallments(
  totalPrice: number,      // fils (whole IQD)
  downPayment: number,      // fils
  months: number,
  frequency: 'weekly' | 'monthly',
  startDate: Date
): Array<{ installmentNumber: number; dueDate: Date; amount: number }> {
  const principal = totalPrice - downPayment;
  const base = Math.floor(principal / months);
  const remainder = principal - base * months;
  
  if (base <= 0) throw new Error("Installment rounds to zero");
  
  const installments = [];
  for (let k = 0; k < months; k++) {
    installments.push({
      installmentNumber: k + 1,
      dueDate: addMonthsOrWeeks(startDate, k, frequency),
      amount: base + (k === months - 1 ? remainder : 0),
    });
  }
  return installments;
}

function addMonthsOrWeeks(date: Date, idx: number, freq: 'weekly' | 'monthly'): Date {
  if (freq === 'weekly') {
    return new Date(date.getTime() + idx * 7 * 24 * 60 * 60 * 1000);
  }
  // Monthly: Use exact backend logic
  const d = new Date(date);
  const totalMonths = d.getMonth() + idx;
  const year = d.getFullYear() + Math.floor(totalMonths / 12);
  const month = totalMonths % 12;
  const day = Math.min(d.getDate(), new Date(year, month + 1, 0).getDate());
  return new Date(year, month, day);
}
```

