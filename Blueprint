```typescript
function calculateInstallments(
  totalPrice: number,
  downPayment: number,
  months: number,
  frequency: 'weekly' | 'monthly',
  startDate: Date
) {
  const principal = totalPrice - downPayment;
  const base = Math.floor(principal / months);
  const remainder = principal - base * months;
  
  if (base <= 0) throw new Error("Installment rounds to zero");
  
  const installments = [];
  for (let k = 0; k < months; k++) {
    installments.push({
      installmentNumber: k + 1,
      dueDate: addMonths(startDate, k),  // or addWeeks
      amount: base + (k === months - 1 ? remainder : 0),
    });
  }
  return installments;
}
```

### 7.5 Payment Allocation Visualizer

**FIFO Visual Logic:**
```typescript
function computeFifoAllocation(installments: Installment[], inputAmount: number) {
  let remainder = inputAmount;
  return installments.map(inst => {
    const remainingToPay = inst.amount - inst.paid;
    if (remainder <= 0) return { ...inst, visualAllocation: 0, visualStatus: 'UNTOUCHED' };
    if (remainder >= remainingToPay) {
      remainder -= remainingToPay;
      return { ...inst, visualAllocation: remainingToPay, visualStatus: 'FULLY_PAID' };
    } else {
      const partial = remainder;
      remainder = 0;
      return { ...inst, visualAllocation: partial, visualStatus: 'PARTIALLY_PAID' };
    }
  });
}
```

