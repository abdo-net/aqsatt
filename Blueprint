## 5. API CLIENT LAYER

### 5.1 Axios Wrapper (src/shared/api/client.ts)

```typescript
import axios from 'axios';
import { toast } from 'react-hot-toast';

export const apiClient = axios.create({
  baseURL: '/api/v1',
  headers: { 'Content-Type': 'application/json' },
  withCredentials: true, // Sends HTTP-Only cookies
  timeout: 30000,
});

// Request interceptor: Add idempotency keys for mutations
apiClient.interceptors.request.use((config) => {
  if (['POST', 'PUT', 'PATCH'].includes(config.method?.toUpperCase() || '')) {
    // Generate idempotency key if not provided
    if (!config.headers['Idempotency-Key'] && !config.data?.idempotency_key) {
      const key = `front-${Date.now()}-${Math.random().toString(36).slice(2, 11)}`;
      if (config.data && typeof config.data === 'object') {
        config.data.idempotency_key = key;
      }
    }
  }
  return config;
});

// Response interceptor: Error handling + retry logic
apiClient.interceptors.response.use(
  (response) => response.data,
  async (error) => {
    const originalRequest = error.config;
    
    // 401 Handling
    if (error.response?.status === 401 && !originalRequest._retry) {
      originalRequest._retry = true;
      try {
        // Attempt refresh (will likely fail due to backend gap, forces re-login)
        await axios.post('/api/auth/refresh', {}, { withCredentials: true });
        return apiClient(originalRequest);
      } catch {
        window.location.href = '/login';
        return Promise.reject(error);
      }
    }

    // Network error retry (1 attempt)
    if (!error.response && !originalRequest._retry) {
      originalRequest._retry = true;
      await new Promise(r => setTimeout(r, 1000));
      return apiClient(originalRequest);
    }

    const apiError = error.response?.data || { detail: 'Network Error' };
    
    if (error.response?.status >= 500) {
      toast.error('System Failure. Please contact support.');
    } else if (error.response?.status === 409) {
      toast.error(apiError.detail || 'Conflict: Record may already exist');
    } else if (error.response?.status === 422) {
      toast.error(apiError.detail || 'Validation failed');
    } else {
      toast.error(apiError.detail || 'Request failed');
    }
    
    return Promise.reject(apiError);
  }
);
```

