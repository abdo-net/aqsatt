### 3.6 Middleware (src/middleware.ts)

```typescript
import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';
import { jwtVerify } from 'jose';

const SECRET = new TextEncoder().encode(process.env.JWT_SECRET || 'dev-secret-change-me');

export async function middleware(request: NextRequest) {
  const token = request.cookies.get('aqsatt_access')?.value;
  const isAuthRoute = request.nextUrl.pathname.startsWith('/login');

  if (!token) {
    return isAuthRoute ? NextResponse.next() : NextResponse.redirect(new URL('/login', request.url));
  }

  try {
    const { payload } = await jwtVerify(token, SECRET, { clockTolerance: 60 });
    const perms = payload.perms as string[];
    
    // RBAC route guards
    const path = request.nextUrl.pathname;
    if (path.startsWith('/settings') && !perms.includes('settings.manage')) {
      return NextResponse.redirect(new URL('/', request.url));
    }
    if (path.startsWith('/products') && !perms.some(p => ['products.read', 'products.write'].includes(p))) {
      return NextResponse.redirect(new URL('/', request.url));
    }
    if (path.startsWith('/pos') && !perms.some(p => ['sales.create', 'sales.read'].includes(p))) {
      return NextResponse.redirect(new URL('/', request.url));
    }

    if (isAuthRoute) return NextResponse.redirect(new URL('/', request.url));
    
    const response = NextResponse.next();
    response.headers.set('x-user-id', payload.sub as string);
    response.headers.set('x-tenant-id', String(payload.tid));
    return response;
  } catch {
    const response = NextResponse.redirect(new URL('/login', request.url));
    response.cookies.delete('aqsatt_access');
    return response;
  }
}

export const config = {
  matcher: ['/((?!api|_next/static|_next/image|favicon.ico).*)'],
};
```

