## 4. BFF PROXY LAYER (CRITICAL)

### 4.1 Catch-All Proxy (src/app/api/v1/[...path]/route.ts)

```typescript
import { NextRequest, NextResponse } from 'next/server';

const API_INTERNAL_URL = process.env.API_INTERNAL_URL || 'http://127.0.0.1:8000';

async function proxyRequest(
  request: NextRequest,
  { params }: { params: { path: string[] } }
) {
  const path = params.path.join('/');
  const searchParams = request.nextUrl.search;
  const backendUrl = `${API_INTERNAL_URL}/api/v1/${path}${searchParams}`;

  // Sanitize headers
  const headers = new Headers(request.headers);
  headers.delete('host');
  
  // Inject auth token from cookie into Authorization header
  const token = request.cookies.get('aqsatt_access')?.value;
  if (token) {
    headers.set('Authorization', `Bearer ${token}`);
  }

  const hasBody = !['GET', 'HEAD'].includes(request.method);
  const body = hasBody ? await request.text() : undefined;

  // AbortController for timeout
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 30000); // 30s timeout

  try {
    const backendResponse = await fetch(backendUrl, {
      method: request.method,
      headers,
      body,
      cache: 'no-store',        // CRITICAL: Never cache proxy requests
      signal: controller.signal,
    });
    clearTimeout(timeout);

    const data = await backendResponse.text();
    const responseHeaders = new Headers(backendResponse.headers);
    
    // Remove headers that conflict with Next.js
    responseHeaders.delete('content-encoding');
    responseHeaders.delete('transfer-encoding');

    return new NextResponse(data, {
      status: backendResponse.status,
      headers: responseHeaders,
    });
  } catch (error) {
    clearTimeout(timeout);
    if ((error as Error).name === 'AbortError') {
      return NextResponse.json(
        { error_code: 'GATEWAY_TIMEOUT', message: 'Backend request timed out' },
        { status: 504 }
      );
    }
    console.error('[PROXY ERROR]:', error);
    return NextResponse.json(
      { error_code: 'GATEWAY_ERROR', message: 'Backend unreachable' },
      { status: 502 }
    );
  }
}

export const GET = proxyRequest;
export const POST = proxyRequest;
export const PUT = proxyRequest;
export const PATCH = proxyRequest;
export const DELETE = proxyRequest;
```

### 4.2 Auth Proxy Route (src/app/api/auth/login/route.ts)

```typescript
import { NextRequest, NextResponse } from 'next/server';
import { cookies } from 'next/headers';

const API_INTERNAL_URL = process.env.API_INTERNAL_URL || 'http://127.0.0.1:8000';

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    
    const backendResponse = await fetch(`${API_INTERNAL_URL}/api/v1/auth/login`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (!backendResponse.ok) {
      return NextResponse.json(await backendResponse.json(), { status: backendResponse.status });
    }

    const data = await backendResponse.json();

    const cookieStore = cookies();
    const isProduction = process.env.NODE_ENV === 'production';

    // Access token cookie
    cookieStore.set({
      name: 'aqsatt_access',
      value: data.access_token,
      httpOnly: true,
      secure: isProduction,
      sameSite: 'lax',
      path: '/',
      maxAge: 60 * 15, // 15 minutes
    });

    // NOTE: Backend does NOT return refresh_token. This is a known gap.
    // Workaround: Set access token with longer expiry in separate cookie
    // or implement server-side session cache.
    // cookieStore.set({
    //   name: 'aqsatt_refresh',
    //   value: data.access_token, // Fallback: same token
    //   httpOnly: true,
    //   secure: isProduction,
    //   sameSite: 'lax',
    //   path: '/',
    //   maxAge: 60 * 60 * 24 * 7, // 7 days
    // });

    return NextResponse.json({ 
      success: true, 
      user: {
        id: data.user_id,
        name: body.username,
        tenant_id: data.tenant_id,
        permissions: data.permissions,
      }
    });
  } catch (error) {
    console.error('[LOGIN ERROR]:', error);
    return NextResponse.json({ error: 'Internal Server Error' }, { status: 500 });
  }
}
